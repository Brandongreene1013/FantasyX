{
  "name": "fantasyx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:a11y": "playwright test",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:load": "node scripts/load-test.mjs",
    "verify": "node scripts/verify.mjs --full",
    "verify:full": "node scripts/verify.mjs --full",
    "verify:fast": "node scripts/verify.mjs --fast",
    "db:check": "node scripts/db-check.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:prepare": "npm run db:migrate && npm run prisma:seed",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "arctic": "^3.7.0",
    "clsx": "^2.1.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "qrcode": "^1.5.4",
    "recharts": "^3.9.0",
    "otplib": "^13.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/qrcode": "^1.5.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.5.10",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
