generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerPosition {
  QB
  RB
  WR
  TE
}

enum ThresholdType {
  TOP_3
  TOP_5
  TOP_10
}

enum MarketStatus {
  DRAFT
  SCHEDULED
  OPEN
  LOCKED
  SETTLED
  VOID
}

enum MarketResult {
  YES
  NO
}

enum TradeSide {
  YES
  NO
}

enum LedgerEntryType {
  SEED_GRANT
  TRADE_SPEND
  TRADE_PROCEEDS
  SETTLEMENT_PAYOUT
  VOID_REFUND
  ADMIN_ADJUSTMENT
  CORRECTION
}

enum TradeAction {
  BUY
  SELL
}

enum MarketEventType {
  TRADE
  PRICE_CHANGE
  LOCK
  UNLOCK
  SETTLE
  VOID
  ADMIN_NOTE
}

enum AdminAuditAction {
  SETTLEMENT
  VOID
  LOCK
  UNLOCK
  MARKET_EDIT
  MARKET_CREATE
  BULK_OPEN
  BULK_LOCK
  BULK_VOID
  WEEK_CREATE
  WEEK_ACTIVATE
  WEEK_DEACTIVATE
  WEEK_ARCHIVE
  SCORE_IMPORT
  SETTLEMENT_BATCH
  KICKOFF_LOCK
}

enum ImportStatus {
  PENDING
  VALIDATED
  IMPORTED
  FAILED
}

enum UserRole {
  TRADER
  ADMIN
}

enum BetaEventType {
  SIGNUP
  REFERRAL_SIGNUP
  ONBOARDING_COMPLETE
  FIRST_TRADE
  MARKET_SHARE
  INVITE_COPY
}

model User {
  id              String             @id @default(cuid())
  name            String
  email           String?            @unique
  firstName       String             @default("") @map("first_name")
  lastName        String             @default("") @map("last_name")
  displayName     String             @default("") @map("display_name")
  passwordHash    String             @default("") @map("password_hash")
  role            UserRole           @default(TRADER)
  walletAddress   String?            @unique @map("wallet_address")
  isAdmin         Boolean            @default(false) @map("is_admin")
  mockBalance      Decimal            @default(1000) @map("mock_balance") @db.Decimal(14, 2)
  startingBalance  Decimal            @default(1000) @map("starting_balance") @db.Decimal(14, 2)
  favoriteTeam     String?            @map("favorite_team")
  onboardingDone   Boolean            @default(false) @map("onboarding_done")
  referralCode     String?            @unique @map("referral_code")
  referredByUserId String?            @map("referred_by_user_id")
  referredBy       User?              @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals        User[]             @relation("UserReferrals")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  trades           Trade[]
  positions        Position[]
  settlements      Settlement[]
  leaderboard      LeaderboardEntry[]
  ledgerEntries    AccountLedgerEntry[]
  administeredLedgerEntries AccountLedgerEntry[] @relation("LedgerAdmin")
  adminAudits      AdminAuditLog[]
  marketEvents     MarketEvent[]
  sessions         Session[]
  scoreImports     ScoreImport[]
  watchedMarkets   WatchMarket[]
  betaEvents       BetaEvent[]         @relation("BetaEventUser")
  betaReferrals    BetaEvent[]         @relation("BetaEventReferrer")

  @@index([referredByUserId])
  @@map("users")
}

model BetaEvent {
  id         String        @id @default(cuid())
  type       BetaEventType
  userId     String?       @map("user_id")
  user       User?         @relation("BetaEventUser", fields: [userId], references: [id], onDelete: SetNull)
  marketId   String?       @map("market_id")
  referrerId String?       @map("referrer_id")
  referrer   User?         @relation("BetaEventReferrer", fields: [referrerId], references: [id], onDelete: SetNull)
  metadata   Json?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([marketId, createdAt])
  @@index([referrerId, createdAt])
  @@map("beta_events")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Player {
  id                 String         @id
  name               String
  team               String
  position           PlayerPosition
  status             String         @default("ACTIVE")
  externalProviderId String?        @unique @map("external_provider_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  markets            Market[]
  playerScores       PlayerScore[]

  @@map("players")
}

model NflWeek {
  id           String             @id
  season       Int
  week         Int
  startsAt     DateTime           @map("starts_at")
  endsAt       DateTime           @map("ends_at")
  status       String             @default("SCHEDULED")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  games        Game[]
  markets      Market[]
  entries      LeaderboardEntry[]
  scoreImports ScoreImport[]
  playerScores PlayerScore[]

  @@unique([season, week])
  @@map("nfl_weeks")
}

model Game {
  id                 String   @id @default(cuid())
  weekId             String   @map("week_id")
  week               NflWeek  @relation(fields: [weekId], references: [id])
  homeTeam           String   @map("home_team")
  awayTeam           String   @map("away_team")
  kickoffTime        DateTime @map("kickoff_time")
  externalProviderId String?  @unique @map("external_provider_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  markets            Market[]

  @@index([weekId])
  @@index([kickoffTime])
  @@map("games")
}

model Market {
  id            String         @id
  playerId      String         @map("player_id")
  player        Player         @relation(fields: [playerId], references: [id])
  weekId        String         @map("week_id")
  week          NflWeek        @relation(fields: [weekId], references: [id])
  gameId        String?        @map("game_id")
  game          Game?          @relation(fields: [gameId], references: [id])
  position      PlayerPosition
  thresholdType ThresholdType  @map("threshold_type")
  yesPrice      Decimal        @map("yes_price") @db.Decimal(8, 6)
  noPrice       Decimal        @map("no_price") @db.Decimal(8, 6)
  openingPrice  Decimal        @default(0) @map("opening_price") @db.Decimal(8, 6)
  yesPool       Decimal        @map("yes_pool") @db.Decimal(14, 6)
  noPool        Decimal        @map("no_pool") @db.Decimal(14, 6)
  volume        Decimal        @default(0) @db.Decimal(14, 2)
  openInterest  Decimal        @default(0) @map("open_interest") @db.Decimal(14, 6)
  status        MarketStatus   @default(OPEN)
  result        MarketResult?
  kickoffTime   DateTime       @map("kickoff_time")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  trades        Trade[]
  positions     Position[]
  settlement    Settlement?
  ledgerEntries AccountLedgerEntry[]
  events        MarketEvent[]
  priceHistory  MarketPriceHistory[]
  auditLogs     AdminAuditLog[]
  watchedBy     WatchMarket[]

  @@unique([playerId, weekId, thresholdType])
  @@index([weekId, position])
  @@index([status, kickoffTime])
  @@map("markets")
}

model MarketPriceHistory {
  id           String   @id @default(cuid())
  marketId     String   @map("market_id")
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  yesPrice     Decimal  @map("yes_price") @db.Decimal(8, 6)
  noPrice      Decimal  @map("no_price") @db.Decimal(8, 6)
  liquidity    Decimal  @db.Decimal(14, 6)
  volume       Decimal  @db.Decimal(14, 2)
  openInterest Decimal  @map("open_interest") @db.Decimal(14, 6)
  source       String   @default("MARKET_EVENT")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([marketId, createdAt])
  @@map("market_price_history")
}

model Trade {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  marketId    String    @map("market_id")
  market      Market    @relation(fields: [marketId], references: [id])
  action      TradeAction @default(BUY)
  side        TradeSide
  spend       Decimal   @db.Decimal(14, 2)
  shares      Decimal   @db.Decimal(14, 6)
  priceBefore Decimal   @map("price_before") @db.Decimal(8, 6)
  priceAfter  Decimal   @map("price_after") @db.Decimal(8, 6)
  idempotencyKey String? @unique @map("idempotency_key")
  createdAt   DateTime  @default(now()) @map("created_at")
  ledgerEntries AccountLedgerEntry[]
  events      MarketEvent[]

  @@index([userId, createdAt])
  @@index([marketId, createdAt])
  @@map("trades")
}

model Position {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  marketId  String   @map("market_id")
  market    Market   @relation(fields: [marketId], references: [id])
  yesShares Decimal  @default(0) @map("yes_shares") @db.Decimal(14, 6)
  noShares  Decimal  @default(0) @map("no_shares") @db.Decimal(14, 6)
  costBasis Decimal  @default(0) @map("cost_basis") @db.Decimal(14, 2)
  realizedPayout Decimal @default(0) @map("realized_payout") @db.Decimal(14, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, marketId])
  @@index([marketId])
  @@map("positions")
}

model Settlement {
  id                  String        @id @default(cuid())
  marketId            String        @unique @map("market_id")
  market              Market        @relation(fields: [marketId], references: [id])
  settledById         String?       @map("settled_by_id")
  settledBy           User?         @relation(fields: [settledById], references: [id])
  result              MarketResult
  fantasyPoints       Decimal?      @map("fantasy_points") @db.Decimal(8, 2)
  positionalRank      Int?          @map("positional_rank")
  scoringFormat       String        @default("HALF_PPR") @map("scoring_format")
  settledAt           DateTime      @default(now()) @map("settled_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  ledgerEntries       AccountLedgerEntry[]
  events              MarketEvent[]

  @@index([settledAt])
  @@map("settlements")
}

model AccountLedgerEntry {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  user           User             @relation(fields: [userId], references: [id])
  type           LedgerEntryType
  amount         Decimal          @db.Decimal(14, 2)
  balanceAfter   Decimal          @map("balance_after") @db.Decimal(14, 2)
  tradeId        String?          @map("trade_id")
  trade          Trade?           @relation(fields: [tradeId], references: [id])
  settlementId   String?          @map("settlement_id")
  settlement     Settlement?      @relation(fields: [settlementId], references: [id])
  marketId       String?          @map("market_id")
  market         Market?          @relation(fields: [marketId], references: [id])
  adminId        String?          @map("admin_id")
  admin          User?            @relation("LedgerAdmin", fields: [adminId], references: [id])
  reason         String?
  metadata       Json?
  idempotencyKey String           @unique @map("idempotency_key")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([marketId, createdAt])
  @@index([tradeId])
  @@index([settlementId])
  @@index([adminId, createdAt])
  @@index([type, createdAt])
  @@map("account_ledger_entries")
}

model AdminAuditLog {
  id          String           @id @default(cuid())
  actorId     String           @map("actor_id")
  actor       User             @relation(fields: [actorId], references: [id])
  action      AdminAuditAction
  marketId    String?          @map("market_id")
  market      Market?          @relation(fields: [marketId], references: [id])
  weekId      String?          @map("week_id")
  playerId    String?          @map("player_id")
  reason      String?
  previousState String?        @map("previous_state")
  nextState   String?          @map("next_state")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([marketId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}

model MarketEvent {
  id          String          @id @default(cuid())
  marketId    String          @map("market_id")
  market      Market          @relation(fields: [marketId], references: [id])
  type        MarketEventType
  userId      String?         @map("user_id")
  user        User?           @relation(fields: [userId], references: [id])
  tradeId     String?         @map("trade_id")
  trade       Trade?          @relation(fields: [tradeId], references: [id])
  settlementId String?        @map("settlement_id")
  settlement  Settlement?     @relation(fields: [settlementId], references: [id])
  priceBefore Decimal?        @map("price_before") @db.Decimal(8, 6)
  priceAfter  Decimal?        @map("price_after") @db.Decimal(8, 6)
  liquidity   Decimal?        @db.Decimal(14, 6)
  volume      Decimal?        @db.Decimal(14, 2)
  openInterest Decimal?       @map("open_interest") @db.Decimal(14, 6)
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([marketId, createdAt])
  @@index([type, createdAt])
  @@map("market_events")
}

model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  weekId    String   @map("week_id")
  week      NflWeek  @relation(fields: [weekId], references: [id])
  pnl       Decimal  @default(0) @db.Decimal(14, 2)
  rank      Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekId])
  @@index([weekId, rank])
  @@map("leaderboard_entries")
}

model ScoreImport {
  id         String        @id @default(cuid())
  weekId     String        @map("week_id")
  week       NflWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  adminId    String        @map("admin_id")
  admin      User          @relation(fields: [adminId], references: [id])
  filename   String
  status     ImportStatus  @default(PENDING)
  rowCount   Int           @default(0) @map("row_count")
  errorCount Int           @default(0) @map("error_count")
  errors     Json?
  createdAt  DateTime      @default(now()) @map("created_at")
  scores     PlayerScore[]

  @@index([weekId])
  @@index([adminId])
  @@map("score_imports")
}

model OperationLog {
  id         String    @id @default(cuid())
  type       String
  status     String    @default("RUNNING")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  durationMs Int?      @map("duration_ms")
  summary    Json?
  error      String?
  actorId    String?   @map("actor_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([status, createdAt])
  @@map("operation_logs")
}

model PlayerScore {
  id             String      @id @default(cuid())
  importId       String      @map("import_id")
  import         ScoreImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  playerId       String      @map("player_id")
  player         Player      @relation(fields: [playerId], references: [id])
  weekId         String      @map("week_id")
  week           NflWeek     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  fantasyPoints  Decimal     @default(0) @map("fantasy_points") @db.Decimal(8, 2)
  positionalRank Int         @default(0) @map("positional_rank")
  overallRank    Int?        @map("overall_rank")
  passYards      Int         @default(0) @map("pass_yards")
  passTDs        Int         @default(0) @map("pass_tds")
  interceptions  Int         @default(0)
  rushYards      Int         @default(0) @map("rush_yards")
  rushTDs        Int         @default(0) @map("rush_tds")
  receptions     Int         @default(0)
  recYards       Int         @default(0) @map("rec_yards")
  recTDs         Int         @default(0) @map("rec_tds")
  fumbles        Int         @default(0)
  twoPointConv   Int         @default(0) @map("two_point_conv")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([weekId])
  @@index([playerId])
  @@index([importId])
  @@map("player_scores")
}

model WatchMarket {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  marketId  String   @map("market_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId])
  @@index([userId])
  @@map("watch_markets")
}
