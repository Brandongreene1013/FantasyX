# Required server-side database connection.
# Recommended for reliable local verification: use a hosted dev Postgres URL
# from Neon, Supabase, Vercel Postgres, or another disposable dev database.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/fantasyx_dev?sslmode=require"
#
# Optional local Docker default:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fantasyx?schema=public"
SESSION_SECRET="replace-with-at-least-32-random-characters"
# Public origin used to build verification and OAuth callback URLs.
AUTH_BASE_URL="http://localhost:3000"
# Required for authenticated scheduled jobs and deep health checks.
# CRON_SECRET="replace-with-a-random-32-byte-secret"

# Solana foundation. Devnet/localnet only during this sprint; do not enable
# mainnet transaction support until the on-chain release process exists.
SOLANA_CLUSTER="devnet"
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"
SOLANA_RPC_URL="https://api.devnet.solana.com"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_FANTASYX_MARKET_PROGRAM_ID="Fx11111111111111111111111111111111111111111"
SOLANA_ALLOW_MAINNET_TRANSACTIONS="false"

# Beta NFL schedules, live scores, and player game statistics.
# Keep the key server-side; never expose it through NEXT_PUBLIC_* variables.
# NFL_DATA_PROVIDER="api-sports"
# NFL_DATA_API_KEY="your-api-sports-key"

# Transactional authentication email (verification and password reset).
# RESEND_API_KEY="re_..."
# AUTH_EMAIL_FROM="FantasyX <accounts@your-verified-domain.com>"

# Social sign-in. Buttons appear only for fully configured providers.
# Google callback: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="..."

# Microsoft callback: http://localhost:3000/api/auth/callback/microsoft
# MICROSOFT_CLIENT_ID="..."
# MICROSOFT_CLIENT_SECRET="..."

# Apple callback: https://YOUR-DOMAIN/api/auth/callback/apple
# Apple web sign-in requires a real HTTPS domain and does not accept localhost.
# APPLE_CLIENT_ID="com.yourcompany.fantasyx.web"
# APPLE_TEAM_ID="..."
# APPLE_KEY_ID="..."
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Seed-only administrator identity. Runtime login never promotes accounts from env values.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"
ADMIN_FIRST_NAME="FantasyX"
ADMIN_LAST_NAME="Admin"

# Vercel/Neon production:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Durable rate limiting (recommended before production).
# Create a free Redis database at https://console.upstash.com and copy the
# REST URL + token. When unset, rate limits fall back to a per-process
# in-memory store (fine for local dev, weak on Vercel).
# UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"
# Vercel Marketplace aliases are also supported automatically:
# KV_REST_API_URL="https://YOUR-DB.upstash.io"
# KV_REST_API_TOKEN="your-rest-token"
